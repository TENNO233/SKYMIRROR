# =============================================================================
# SKYMIRROR - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
OPENAI_AGENT_MODEL=gpt-5.4-mini
OPENAI_VLM_MODEL=gpt-5.4
OPENAI_GUARDRAIL_MODEL=gpt-5.4-mini
OPENAI_VALIDATOR_MODEL=gpt-5.4
OPENAI_EXPERT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=openai
VLM_MAX_TOKENS=2048
VLM_TEMPERATURE=0.0
GUARDRAIL_MAX_TOKENS=256
GUARDRAIL_TEMPERATURE=0.0
VALIDATOR_MAX_TOKENS=640
VALIDATOR_TEMPERATURE=0.0
EXPERT_MAX_TOKENS=512
EXPERT_TEMPERATURE=0.0
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200

# --- Pinecone (Vector DB for RAG) --------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=skymirror-rag
PINECONE_INDEX_HOST=your-index-host.svc.aped-4627-b74a.pinecone.io
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_INDEX_METRIC=cosine
# Optional override. Leave blank to infer from the embedding model automatically.
PINECONE_INDEX_DIMENSION=1536
PINECONE_INDEX_READY_TIMEOUT_SECONDS=180

# --- Singapore corpus bootstrap ----------------------------------------------
SINGAPORE_CORPUS_HTTP_TIMEOUT_SECONDS=60

# --- Application Settings ----------------------------------------------------
PROCESSING_INTERVAL_SECONDS=20          # How often to ingest a new camera frame
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
PYTHONPATH=src                          # Required for LangGraph Studio with src/ layout

# --- LangSmith Tracing -------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=skymirror
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Optional when your API key belongs to multiple workspaces.
LANGSMITH_WORKSPACE_ID=

# --- Camera / Ingestion ------------------------------------------------------
TARGET_CAMERA_ID=4798                   # LTA camera ID to poll (see API docs)
FRAMES_DIR=data/frames                  # Directory where fetched frames are saved
KEEP_FRAME_HISTORY=true                 # true = keep timestamped history; false = latest only

# --- Alerting ----------------------------------------------------------------
ALERT_WEBHOOK_URL=https://hooks.example.com/services/...

# --- LTA DataMall (Real-Time Corroboration) ----------------------------------
LTA_API_KEY=                            # Request at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
