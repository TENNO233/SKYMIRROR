# =============================================================================
# SKYMIRROR — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Pinecone (Vector DB for RAG) --------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1          # e.g. us-east-1, gcp-starter
PINECONE_INDEX_NAME=skymirror-rag
PINECONE_NAMESPACE=production

# --- Application Settings ----------------------------------------------------
PROCESSING_INTERVAL_SECONDS=20         # How often to ingest a new camera frame
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# --- Camera / Ingestion ------------------------------------------------------
TARGET_CAMERA_ID=4798                   # LTA camera ID to poll (see API docs)
FRAMES_DIR=data/frames                  # Directory where fetched frames are saved
KEEP_FRAME_HISTORY=true                 # true = keep timestamped history; false = latest only

# --- Alerting ----------------------------------------------------------------
ALERT_WEBHOOK_URL=https://hooks.example.com/services/...
