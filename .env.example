# =============================================================================
# SKYMIRROR - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
GEMINI_API_KEY=AIza...
GEMINI_VLM_MODEL=gemini-3.1-pro-preview
GEMINI_VALIDATOR_MODEL=gemini-3.1-pro-preview
GEMINI_GUARDRAIL_MODEL=gemini-3.1-pro-preview
GEMINI_EXPERT_MODEL=gemini-3.1-pro-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_VLM_MODEL=qwen3.6-plus
VLM_MAX_TOKENS=384
VLM_TEMPERATURE=0.0
EXPERT_MAX_TOKENS=512
EXPERT_TEMPERATURE=0.0
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200

# --- Pinecone (Vector DB for RAG) --------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=skymirror-rag
PINECONE_INDEX_HOST=your-index-host.svc.aped-4627-b74a.pinecone.io
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_INDEX_METRIC=cosine
# Optional override. Leave blank to infer from the embedding model automatically.
PINECONE_INDEX_DIMENSION=1024
PINECONE_INDEX_READY_TIMEOUT_SECONDS=180

# --- Singapore corpus bootstrap ----------------------------------------------
SINGAPORE_CORPUS_HTTP_TIMEOUT_SECONDS=60

# --- Application Settings ----------------------------------------------------
PROCESSING_INTERVAL_SECONDS=20          # How often to ingest a new camera frame
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# --- Camera / Ingestion ------------------------------------------------------
TARGET_CAMERA_ID=4798                   # LTA camera ID to poll (see API docs)
FRAMES_DIR=data/frames                  # Directory where fetched frames are saved
KEEP_FRAME_HISTORY=true                 # true = keep timestamped history; false = latest only

# --- Alerting ----------------------------------------------------------------
ALERT_WEBHOOK_URL=https://hooks.example.com/services/...

# --- LTA DataMall (Real-Time Corroboration) ----------------------------------
LTA_API_KEY=                            # Request at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
