__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Virtual Environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Tooling Caches
# =============================================================================
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml

# =============================================================================
# Secrets & Environment Files
# NOTE: .env.example is intentionally NOT ignored — commit it as a template.
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# SKYMIRROR — Runtime Data Directories
# Keep the directory structure; ignore generated content.
# =============================================================================

# Camera frames downloaded at runtime
data/frames/*
!data/frames/.gitkeep

# JSONL event / audit logs
data/logs/*
!data/logs/.gitkeep

# Generated PDF / HTML reports
data/reports/*
!data/reports/.gitkeep

# LangGraph Studio / local graph artifacts
.langgraph_api/
data/langgraph/
data/graph/

# Local vector DB (Chroma, FAISS, etc.) — never commit index files
data/local_vector_db/*
!data/local_vector_db/.gitkeep

# Ad-hoc test images dropped in the repo root
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp

# =============================================================================
# OS & IDE
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini

.vscode/
.idea/
*.swp
*.swo

# Daily Explication Report runtime outputs
data/oa_log/
data/reports/

# Local virtualenv
.venv/
